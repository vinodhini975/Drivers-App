platform :ios, '15.0'

ENV['COCOAPODS_DISABLE_STATS'] = 'true'

project 'Runner', {
  'Debug' => :debug,
  'Profile' => :release,
  'Release' => :release,
}

def flutter_root
  generated_xcode_build_settings_path = File.expand_path(File.join(__dir__, 'Flutter', 'Generated.xcconfig'))
  unless File.exist?(generated_xcode_build_settings_path)
    raise "#{generated_xcode_build_settings_path} must exist. Run flutter pub get first"
  end

  File.foreach(generated_xcode_build_settings_path) do |line|
    matches = line.match(/FLUTTER_ROOT\=(.*)/)
    return matches[1].strip if matches
  end

  raise "FLUTTER_ROOT not found in #{generated_xcode_build_settings_path}"
end

require File.expand_path(File.join('packages', 'flutter_tools', 'bin', 'podhelper'), flutter_root)

flutter_ios_podfile_setup

target 'Runner' do
  use_frameworks! :linkage => :static

  flutter_install_all_ios_pods File.dirname(File.realpath(__FILE__))

  target 'RunnerTests' do
    inherit! :search_paths
  end
end

post_install do |installer|
  installer.pods_project.targets.each do |target|
    flutter_additional_ios_build_settings(target)

    target.build_configurations.each do |config|
      # 1. Ensure consistent deployment target across all pods (iOS 15.0 required for Firebase SDK 12.6.0)
      config.build_settings['IPHONEOS_DEPLOYMENT_TARGET'] = '15.0'
      
      # 2. Force ARM64 for simulator on Apple Silicon
      config.build_settings['EXCLUDED_ARCHS[sdk=iphonesimulator*]'] = 'i386 x86_64'

      # 3. Force C++17 and suppress warnings
      config.build_settings['CLANG_CXX_LANGUAGE_STANDARD'] = 'c++17'
      config.build_settings['GCC_WARN_INHIBIT_ALL_WARNINGS'] = 'YES'
      config.build_settings['DEFINES_MODULE'] = 'YES'
      config.build_settings['CLANG_ALLOW_NON_MODULAR_INCLUDES_IN_FRAMEWORK_MODULES'] = 'YES'

      # 4. Strip the unsupported '-G' flag from all targets and both C/C++ flags
      ['OTHER_CFLAGS', 'OTHER_CPLUSPLUSFLAGS'].each do |key|
        flags = config.build_settings[key]
        if flags.is_a?(Array)
          config.build_settings[key].reject! { |flag| flag == '-G' }
        elsif flags.is_a?(String)
          config.build_settings[key] = flags.gsub(/\b-G\b/, '').strip
        end
      end
    end

    # 4. Strip the flag from per-file settings (Crucial for BoringSSL)
    target.build_phases.each do |phase|
      if phase.respond_to?(:files)
        phase.files.each do |file|
          if file.settings && file.settings.has_key?('COMPILER_FLAGS')
            flags = file.settings['COMPILER_FLAGS']
            if flags.is_a?(String)
              # Broadly remove -G (standalone word) and also check for -GCC_ which causes issues
              new_flags = flags.gsub(/\b-G\b/, '').gsub('-GCC_WARN_INHIBIT_ALL_WARNINGS', '').strip
              file.settings['COMPILER_FLAGS'] = new_flags
            end
          end
        end
      end
    end
  end

  # 5. Direct fix for gRPC template parsing error in all gRPC pods
  Dir.glob('Pods/**/basic_seq.h').each do |basic_seq_path|
    if File.exist?(basic_seq_path)
      puts "Checking #{basic_seq_path} for template fix..."
      # Make the file writable if it's read-only
      FileUtils.chmod(0644, basic_seq_path)
      content = File.read(basic_seq_path)
      if content.include?('Traits::template CallSeqFactory')
        puts "Applying fix to #{basic_seq_path}..."
        content.gsub!('Traits::template CallSeqFactory', 'Traits::CallSeqFactory')
        File.open(basic_seq_path, 'w') { |file| file.puts content }
        puts "Fix applied successfully."
      end
    end
  end
end
